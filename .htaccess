# ===========================================================================
# Geografías de la memoria — configuración de hosting (Hostinger / Apache · LiteSpeed)
# ===========================================================================

# --- Forzar HTTPS (descomentar si el SSL ya está activo en Hostinger) -------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# --- Página por defecto -----------------------------------------------------
DirectoryIndex index.html

# --- Compresión (gzip) ------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml application/xml
</IfModule>

# --- Caché del navegador ----------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  # Imágenes: 1 año (no cambian; si reemplazás una, cambiá el nombre)
  ExpiresByType image/jpeg              "access plus 1 year"
  ExpiresByType image/png               "access plus 1 year"
  ExpiresByType image/webp              "access plus 1 year"
  ExpiresByType image/svg+xml           "access plus 1 year"
  ExpiresByType image/x-icon            "access plus 1 year"
  # JS vendorizado: 1 mes
  ExpiresByType application/javascript  "access plus 1 month"
  # Fuentes
  ExpiresByType font/woff2              "access plus 1 year"
  # HTML: sin caché (para ver cambios al instante)
  ExpiresByType text/html               "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  # Imágenes y JS inmutables
  <FilesMatch "\.(jpg|jpeg|png|webp|svg|ico|woff2|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  # Cabeceras de seguridad básicas
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# --- Charset por defecto ----------------------------------------------------
AddDefaultCharset UTF-8
